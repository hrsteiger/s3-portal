# S3 / MinIO
S3_BUCKET=my-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://localhost:9000   # remove for real AWS

# OIDC provider
OIDC_ISSUER=https://your-idp.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# In-cluster upload key (mount from K8s Secret in production)
UPLOAD_API_KEY=change-me-generate-with-secrets.token_urlsafe-32

# Session signing
SECRET_KEY=change-me-before-going-to-production
